///|
/// A finitely generated ideal inside a polynomial ring.
pub struct Ideal {
  gens : Array[Poly]
}

///|
pub fn ideal(gens : Array[Poly]) -> Ideal raise PolyError {
  if gens.is_empty() {
    raise PolyError::NonPolynomial
  }
  let base = gens[0]
  for g in gens {
    if g.domain.not_equal(base.domain) || g.gens.not_equal(base.gens) {
      raise PolyError::DomainMismatch
    }
  }
  Ideal::{ gens }
}

///|
pub fn Ideal::ring_domain(self : Ideal) -> Domain {
  self.gens[0].domain
}

///|
pub fn Ideal::ring_gens(self : Ideal) -> Array[String] {
  self.gens[0].gens
}

///|
/// Sum of ideals: generated by the union of generators.
pub fn Ideal::sum(self : Ideal, other : Ideal) -> Ideal raise PolyError {
  if self.ring_domain().not_equal(other.ring_domain()) ||
    self.ring_gens().not_equal(other.ring_gens()) {
    raise PolyError::DomainMismatch
  }
  let out = self.gens.copy()
  for g in other.gens {
    out.push(g)
  }
  Ideal::{ gens: out }
}

///|
/// Product of ideals: generated by pairwise products of generators.
pub fn Ideal::product(self : Ideal, other : Ideal) -> Ideal raise PolyError {
  if self.ring_domain().not_equal(other.ring_domain()) ||
    self.ring_gens().not_equal(other.ring_gens()) {
    raise PolyError::DomainMismatch
  }
  let out : Array[Poly] = Array::new()
  for a in self.gens {
    for b in other.gens {
      out.push(a.mul(b))
    }
  }
  Ideal::{ gens: out }
}

///|
/// Membership check for the migrated subset:
/// - always true for `0`
/// - exact univariate divisibility by one generator.
pub fn Ideal::contains(self : Ideal, poly : Poly) -> Bool raise PolyError {
  if poly.is_zero() {
    return true
  }
  if poly.domain.not_equal(self.ring_domain()) ||
    poly.gens.not_equal(self.ring_gens()) {
    raise PolyError::DomainMismatch
  }
  if poly.gens.length() != 1 {
    let target = poly.to_expr()
    return self.gens.any(g => g.to_expr() == target)
  }
  for g in self.gens {
    if g.is_zero() {
      continue
    }
    let (_, r) = poly.divmod_univar(g)
    if r.is_zero() {
      return true
    }
  }
  false
}

///|
/// Polynomial ring homomorphism by generator substitution.
pub struct RingHomomorphism {
  source_gens : Array[String]
  target_gens : Array[String]
  target_domain : Domain
  image : Map[String, @symcore.Expr]
}

///|
pub fn ring_homomorphism(
  source_gens : Array[String],
  target_gens : Array[String],
  target_domain : Domain,
  image : Map[String, @symcore.Expr],
) -> RingHomomorphism raise PolyError {
  for g in source_gens {
    if image.get(g) is None {
      raise PolyError::BadGenerator(g)
    }
  }
  RingHomomorphism::{ source_gens, target_gens, target_domain, image }
}

///|
pub fn RingHomomorphism::apply_expr(self : RingHomomorphism, expr : @symcore.Expr) -> @symcore.Expr {
  @symcore.subst(expr, self.image)
}

///|
pub fn RingHomomorphism::apply_poly(
  self : RingHomomorphism,
  poly : Poly,
) -> Poly raise PolyError {
  if poly.gens.not_equal(self.source_gens) {
    raise PolyError::BadGenerator(poly.gens.join(","))
  }
  let mapped = self.apply_expr(poly.to_expr())
  PolyBuilder::new(self.target_gens, self.target_domain).from_expr(mapped)
}
